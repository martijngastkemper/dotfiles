#!/usr/bin/env zunit

@setup {

  load ../idea.zsh

}

@test 'test idea without arguments' {

  function open {
    echo "open $@"
  }

  run idea

  assert $state equals 0
  assert $output contains `pwd`

}

@test 'test idea with relative path' {

  function open {
    echo "open $@"
  }

  run idea "bin"

  assert $state equals 0
  assert $output contains $(pwd)"/bin"

  run idea "./bin"

  assert $state equals 0
  assert $output contains $(pwd)"/bin"

}

@test 'test non existing path' {

  run idea "non-existing"

  assert $state equals 1
  assert $output contains "does not exists"

}
