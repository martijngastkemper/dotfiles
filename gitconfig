[alias]
    # Locally exclude file without adding it to .gitignore
    exclude = "!f() { \
        for file in "$@"; do \
            echo "$file" >> .git/info/exclude; \
        done; \
    }; f"

    # Get the release/main/master branch, the check is in that order
    main = "! git rev-parse -q --verify --symbolic release || git rev-parse -q --verify --symbolic main || git rev-parse -q --verify --symbolic master;"

    # Interactive rebase from local branch eg. git rbi master
    rbi = "! git rebase --interactive `git merge-base ${1:-origin/$(git main)} HEAD`"

    # List remote branches
    branches = for-each-ref --sort=committerdate --format=\"%(color:blue)%(authordate:relative)%(color:reset)\t%(color:red)%(authorname)%(color:reset)\t%(color:bold)%(refname:short)%(color:reset)\" refs/remotes

[branch]
    autoSetupMerge = simple
    sort = -committerdate

[column]
    ui = auto

[commit]
    gpgsign = true
    verbose = true

[core]
    attributesfile = ~/.dotfiles/gitattributes
    excludesfile = ~/.dotfiles/gitignore_global
    ignorecase = false
    autocrlf = false
    eol = lf
    pager = delta

[delta]
    hyperlinks = true
    navigate = true  # use n and N to move between diff sections
    side-by-side = true
    true-color = always

[diff]
    algorithm = histogram
    colorMoved = true
    mnemonicPrefix = true
    renames = true

[fetch]
    prune = true
    pruneTags = true
    all = true

[gpg]
    format = ssh

[gpg "ssh"]
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[init]
    defaultBranch = main
    templatedir = ~/.dotfiles/git_template

[interactive]
    diffFilter = delta --color-only

[merge]
    conflictStyle = zdiff3

[merge "composer_json"]
    driver = composer-git-merge-driver %O %A %B %L %P
    name = composer JSON file merge driver
    recursive = binary

[push]
    default = simple
    autoSetupRemote = true
    followTags = true

[rebase]
    abbreviateCommands = true
    autoSquash = true
    autoStash = true

[rerere]
    autoUpdate = true
    # Store how merge conflicts where resolved.
    enable = true

[tag]
    sort = -version:refname

[user]
    name = Martijn Gastkemper
    useConfigOnly = true

[include]
    path = ~/.dotfiles/gitconfig.personal


